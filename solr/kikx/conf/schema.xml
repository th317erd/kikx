<?xml version="1.0" encoding="UTF-8" ?>
<schema name="kikx" version="1.6">

  <!-- ===== Field Types ===== -->

  <fieldType name="string" class="solr.StrField" sortMissingLast="true" docValues="true" />
  <fieldType name="boolean" class="solr.BoolField" sortMissingLast="true" />
  <fieldType name="pint" class="solr.IntPointField" docValues="true" />
  <fieldType name="plong" class="solr.LongPointField" docValues="true" />
  <fieldType name="pfloat" class="solr.FloatPointField" docValues="true" />
  <fieldType name="pdouble" class="solr.DoublePointField" docValues="true" />
  <fieldType name="pdate" class="solr.DatePointField" docValues="true" />

  <!-- English text: stemming, stopwords, lowercase -->
  <fieldType name="text_en" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <tokenizer class="solr.StandardTokenizerFactory" />
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt" />
      <filter class="solr.LowerCaseFilterFactory" />
      <filter class="solr.EnglishPossessiveFilterFactory" />
      <filter class="solr.PorterStemFilterFactory" />
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.StandardTokenizerFactory" />
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt" />
      <filter class="solr.SynonymGraphFilterFactory" synonyms="synonyms.txt" ignoreCase="true" expand="true" />
      <filter class="solr.LowerCaseFilterFactory" />
      <filter class="solr.EnglishPossessiveFilterFactory" />
      <filter class="solr.PorterStemFilterFactory" />
    </analyzer>
  </fieldType>

  <!-- HTML-aware text: strips tags before analysis, then same English pipeline -->
  <fieldType name="text_html" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <charFilter class="solr.HTMLStripCharFilterFactory" />
      <tokenizer class="solr.StandardTokenizerFactory" />
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt" />
      <filter class="solr.LowerCaseFilterFactory" />
      <filter class="solr.EnglishPossessiveFilterFactory" />
      <filter class="solr.PorterStemFilterFactory" />
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.StandardTokenizerFactory" />
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt" />
      <filter class="solr.SynonymGraphFilterFactory" synonyms="synonyms.txt" ignoreCase="true" expand="true" />
      <filter class="solr.LowerCaseFilterFactory" />
      <filter class="solr.EnglishPossessiveFilterFactory" />
      <filter class="solr.PorterStemFilterFactory" />
    </analyzer>
  </fieldType>

  <!-- ===== Fields ===== -->
  <!-- Solr is index-only. All content is retrieved from SQLite by ID. -->
  <!-- Only id and doc_type are stored (needed to map results back to DB). -->

  <!-- Unique key — stored (returned in search results) -->
  <field name="id" type="string" indexed="true" stored="true" required="true" multiValued="false" />

  <!-- Document type discriminator — stored (tells caller which DB table to query) -->
  <field name="doc_type" type="string" indexed="true" stored="true" multiValued="false" />

  <!-- Frame fields — index only -->
  <field name="sessionID" type="string" indexed="true" stored="false" multiValued="false" />
  <field name="interactionID" type="string" indexed="true" stored="false" multiValued="false" />
  <field name="type" type="string" indexed="true" stored="false" multiValued="false" />
  <field name="authorType" type="string" indexed="true" stored="false" multiValued="false" />
  <field name="authorID" type="string" indexed="true" stored="false" multiValued="false" />
  <field name="content_text" type="text_en" indexed="true" stored="false" multiValued="false" />
  <field name="content_html" type="text_html" indexed="true" stored="false" multiValued="false" />
  <field name="timestamp" type="plong" indexed="true" stored="false" multiValued="false" />
  <field name="hidden" type="boolean" indexed="true" stored="false" multiValued="false" />
  <field name="deleted" type="boolean" indexed="true" stored="false" multiValued="false" />

  <!-- Tool log fields — index only -->
  <field name="tool_name" type="string" indexed="true" stored="false" multiValued="false" />
  <field name="tool_note" type="string" indexed="true" stored="false" multiValued="false" />
  <field name="tool_output" type="text_en" indexed="true" stored="false" multiValued="false" />

  <!-- Solr internal version field -->
  <field name="_version_" type="plong" indexed="false" stored="false" />

  <!-- Catch-all text field for general search -->
  <field name="_text_" type="text_en" indexed="true" stored="false" multiValued="true" />

  <!-- ===== Unique Key ===== -->
  <uniqueKey>id</uniqueKey>

  <!-- ===== Copy Fields (feed into catch-all for broad search) ===== -->
  <copyField source="content_text" dest="_text_" />
  <copyField source="content_html" dest="_text_" />
  <copyField source="tool_output" dest="_text_" />
  <copyField source="tool_name" dest="_text_" />
  <copyField source="tool_note" dest="_text_" />

</schema>
